{
  "version": 4,
  "include": [
    "base.json"
  ],
  "configurePresets": [
    {
      "name": "emscripten.wasm32",
      "inherits": "base",
      "toolchainFile": "$env{ARIEO_BUILD_ENV_PACKAGES_OUTPUT_DIR}/conan/host/emscripten.wasm32/conan_toolchain.cmake",
      "architecture":
      {
        "value": "wasm32",
        "strategy": "external"
      },
      "environment": {
        "EMSDK": "$env{DEVCRAFT_WORKSPACE}/emscripten/emsdk-3.1.73",
        "EMSCRIPTEN": "$env{DEVCRAFT_WORKSPACE}/emscripten/emsdk-3.1.73/upstream/emscripten",
        "CLANG_FOR_CODEGEN": "$env{DEVCRAFT_WORKSPACE}/llvm/llvm-21/$env{DEVCRAFT_HOST_TRIPLE}/bin/clang++"
      },
      "cacheVariables": {
        "ARIEO_HOST_OS": "emscripten",
        "TARGET_TRIPLE": "wasm32-unknown-emscripten",
        "CMAKE_CROSSCOMPILING_EMULATOR": "$env{DEVCRAFT_WORKSPACE}/emscripten/emsdk-3.1.73/node/20.18.0_64bit/bin/node",
        "CMAKE_PREFIX_PATH": {
          "type": "PATH",
          "value": "$env{ARIEO_THIRDPARTIES_PACKAGES_OUTPUT_DIR}/conan/emscripten.wasm32"
        }
      }
    }
  ]
}